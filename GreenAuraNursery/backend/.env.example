# Copy to .env (or set in terminal/OS environment) before running backend.

# Preferred single JDBC URL option:
# GREENAURA_DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# GREENAURA_DB_USER=postgres.<project-ref>
# GREENAURA_DB_PASSWORD=your_supabase_db_password

# OR split Supabase parameters (DBConnection will build JDBC URL):
SUPABASE_DB_HOST=aws-1-eu-west-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PASSWORD=your_supabase_db_password

# Optional SSL mode (default is require)
GREENAURA_DB_SSLMODE=require
